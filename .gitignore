# vstac 项目 .gitignore
# 忽略编译中间文件和生成产物

# ================================================================
# C 编译产物
# ================================================================
# 可执行文件
vm/sasm_dump
tests/vm-tests/test_minimal

# 目标文件
*.o
*.obj
*.a
*.lib
*.so
*.dll
*.dylib

# 预编译头
*.gch
*.pch

# 依赖文件
*.d
*.dep

# ================================================================
# Coq 编译产物
# ================================================================
# Coq 编译中间文件
*.vo
*.vio
*.vok
*.vos
*.glob
*.aux

# Coq 编译缓存
.coq-native/
_CoqProject

# ================================================================
# OCaml 编译产物 (Coq Extraction 目标)
# ================================================================
*.cmx
*.cmo
*.cmi
*.cmxa
*.cma
*.o
*.obj
*.exe
*.byte
*.opt

# dune 构建产物
_build/
*.install

# ================================================================
# IDE / 编辑器
# ================================================================
# VS Code
.vscode/settings.json
.vscode/launch.json
*.code-workspace

# Vim
*.swp
*.swo
*.swn
*~

# Emacs
*#
.#*
\#*\#

# ================================================================
# 系统文件
# ================================================================
.DS_Store
Thumbs.db
*.log
*.tmp

# ================================================================
# Python 生成器产物 (保留生成的 .sasm 示例供版本控制)
# ================================================================
__pycache__/
*.pyc
*.pyo

# ================================================================
# 测试生成的文件
# ================================================================
/tests/*.log
/tests/*.out
